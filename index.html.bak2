  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" onclick="closeLightbox(event)">
    <button class="lightbox__close" onclick="closeLightbox(event)" aria-label="Schließen">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <img class="lightbox__img" id="lightboxImg" src="" alt="">
  </div>

  <script src="script.js"></script>
  <script>
    function openLightbox(imgEl) {
      var lb = document.getElementById('lightbox');
      var lbImg = document.getElementById('lightboxImg');
      lbImg.src = imgEl.src;
      lbImg.alt = imgEl.alt;

      /* Get source image rect for FLIP animation */
      var rect = imgEl.getBoundingClientRect();
      lbImg.style.position = 'fixed';
      lbImg.style.left = rect.left + 'px';
      lbImg.style.top = rect.top + 'px';
      lbImg.style.width = rect.width + 'px';
      lbImg.style.height = rect.height + 'px';
      lbImg.style.borderRadius = '12px';
      lbImg.style.transition = 'none';
      lbImg.style.objectFit = 'contain';

      lb.classList.add('lightbox--active');
      document.body.style.overflow = 'hidden';

      /* Force reflow then animate to center */
      void lbImg.offsetWidth;

      /* Calculate final centered position — 70% of viewport, not fullscreen */
      var maxW = window.innerWidth * 0.7;
      var maxH = window.innerHeight * 0.7;
      var vw = maxW;
      var vh = maxH;
      var imgRatio = lbImg.naturalWidth / lbImg.naturalHeight;
      var fw, fh;
      if (vw / vh > imgRatio) {
        fh = vh;
        fw = fh * imgRatio;
      } else {
        fw = vw;
        fh = fw / imgRatio;
      }
      var fl = (window.innerWidth - fw) / 2;
      var ft = (window.innerHeight - fh) / 2;

      lbImg.style.transition = 'all .45s cubic-bezier(.16,1,.3,1)';
      lbImg.style.left = fl + 'px';
      lbImg.style.top = ft + 'px';
      lbImg.style.width = fw + 'px';
      lbImg.style.height = fh + 'px';
      lbImg.style.borderRadius = '16px';

      /* Store source rect for close animation */
      lb._sourceRect = rect;
      lb._sourceImg = imgEl;
    }

    function closeLightbox(e) {
      if (e && e.target.closest('.lightbox__img') && !e.target.closest('.lightbox__close')) return;
      var lb = document.getElementById('lightbox');
      var lbImg = document.getElementById('lightboxImg');
      if (!lb.classList.contains('lightbox--active')) return;

      var rect = lb._sourceRect;
      /* Re-read source position in case of scroll */
      if (lb._sourceImg) {
        rect = lb._sourceImg.getBoundingClientRect();
      }

      lbImg.style.transition = 'all .35s cubic-bezier(.4,0,.2,1)';
      lbImg.style.left = rect.left + 'px';
      lbImg.style.top = rect.top + 'px';
      lbImg.style.width = rect.width + 'px';
      lbImg.style.height = rect.height + 'px';
      lbImg.style.borderRadius = '12px';

      lb.classList.add('lightbox--closing');

      setTimeout(function() {
        lb.classList.remove('lightbox--active', 'lightbox--closing');
        lbImg.style.transition = 'none';
        document.body.style.overflow = '';
      }, 360);
    }

    /* Close on Escape */
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeLightbox(e);
    });

    /* Prevent parent page scrolling while mouse is over demo iframe */
    (function() {
      var demoSection = document.getElementById('demo');
      if (!demoSection) return;
      var demoWrap = demoSection.querySelector('.browser-chrome');
      var demoIframe = demoWrap ? demoWrap.querySelector('iframe') : null;
      if (!demoWrap) return;

      function blockScroll(e) { e.preventDefault(); }
      function blockKeys(e) {
        var keys = [32, 33, 34, 35, 36, 37, 38, 39, 40];
        if (keys.indexOf(e.keyCode) !== -1) e.preventDefault();
      }

      var isHovering = false;
      var savedScrollY = 0;

      demoWrap.addEventListener('mouseenter', function() {
        isHovering = true;
        savedScrollY = window.scrollY;
        window.addEventListener('wheel', blockScroll, { passive: false });
        window.addEventListener('touchmove', blockScroll, { passive: false });
        window.addEventListener('keydown', blockKeys);
      });
      demoWrap.addEventListener('mouseleave', function() {
        isHovering = false;
        window.removeEventListener('wheel', blockScroll);
        window.removeEventListener('touchmove', blockScroll);
        window.removeEventListener('keydown', blockKeys);
      });

      /* Fix: clicking inside iframe (e.g. HAI button) triggers browser auto-scroll-into-view.
         Catch any scroll while hovering the demo and snap back instantly. */
      window.addEventListener('scroll', function() {
        if (isHovering && Math.abs(window.scrollY - savedScrollY) > 2) {
          window.scrollTo(0, savedScrollY);
        }
      }, { passive: true });
    })();
  </script>

  <!-- Cookie Consent Banner (TTDSG / DSGVO 2026) -->
  <div class="cookie-banner" id="cookieBanner" role="dialog" aria-label="Cookie-Einstellungen">
    <div class="cookie-banner__inner">
      <div class="cookie-banner__title">Cookie-Einstellungen</div>
      <p class="cookie-banner__text">Wir verwenden Cookies und ähnliche Technologien, um die Nutzung unserer Website zu analysieren und sie stetig zu verbessern. Technisch notwendige Cookies werden immer gesetzt. Weitere Informationen finden Sie in unserer <a href="datenschutz.html">Datenschutzerklärung</a> und <a href="cookies.html">Cookie-Richtlinie</a>.</p>
      <div class="cookie-banner__actions">
        <button class="cookie-banner__btn cookie-banner__btn--accept" onclick="setCookieConsent('all')">Alle akzeptieren</button>
        <button class="cookie-banner__btn cookie-banner__btn--reject" onclick="setCookieConsent('essential')">Nur notwendige</button>
        <button class="cookie-banner__btn cookie-banner__btn--settings" onclick="setCookieConsent('essential')">Einstellungen</button>
      </div>
    </div>
  </div>
  <script>
    (function() {
      var consent = localStorage.getItem('lfa_cookie_consent');
      if (!consent) {
        setTimeout(function() {
          document.getElementById('cookieBanner').classList.add('cookie-banner--visible');
        }, 800);
      }
    })();
    function setCookieConsent(level) {
      localStorage.setItem('lfa_cookie_consent', JSON.stringify({ level: level, date: new Date().toISOString() }));
      var banner = document.getElementById('cookieBanner');
      banner.classList.remove('cookie-banner--visible');
    }
  </script>

