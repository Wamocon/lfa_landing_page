        <div><div style="color:#ccc;font-size:.67rem;font-weight:700;">Komponente</div><div style="color:#555;font-size:.6rem;">Prüfungseinheit</div></div>
      </div>
      <div class="glgd" title="Praxisaufgabe aus dem Berufsalltag (86 Stück)">
        <div class="glgd-dot" style="width:6px;height:6px;background:#38bdf8;"></div>
        <div><div style="color:#ccc;font-size:.67rem;font-weight:700;">Use Case</div><div style="color:#555;font-size:.6rem;">Praxisaufgabe</div></div>
      </div>
    </div>
    <div id="galaxySvgContainer"></div>
    <div id="galaxyTooltip"></div>
    <p id="galaxyHint" style="position:fixed;bottom:70px;left:50%;transform:translateX(-50%);z-index:9590;color:#4a4a58;font-size:.63rem;letter-spacing:.04em;text-align:center;pointer-events:none;white-space:nowrap;">Klicke auf <span style="color:#ff7777;">Lernfeld</span> oder <span style="color:#c8ccd4;">Komponente</span> zum Einzoomen &nbsp;·&nbsp; Hover für Details</p>
    <input id="galaxySearch" type="text" placeholder="Suchen…" oninput="galaxySearch(this.value)">
  </div>

  <!-- ── ZOOM LAYER ── -->
  <div id="zoomLayer"><div id="zoomCircle"></div></div>
