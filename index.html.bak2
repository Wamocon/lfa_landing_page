  <!-- HAI Deep — Technologie & Prinzipien -->
  <section class="py-24 md:py-36 section-hai-deep" id="hai-deep">
    <div class="max-w-[1100px] mx-auto px-5 md:px-10">

      <!-- Heading -->
      <div class="text-center mb-16 md:mb-20">
        <span class="reveal inline-block text-xs font-semibold tracking-widest uppercase px-3 py-1 rounded mb-4" style="color:#818cf8;background:rgba(129,140,248,.1);border:1px solid rgba(129,140,248,.2);">Technologie</span>
        <h2 class="reveal text-3xl md:text-5xl font-bold leading-[1.1] tracking-tight mb-5" style="color:#f0f0f2;">Wie HAI <span style="background:linear-gradient(135deg,#38bdf8,#818cf8,#c084fc);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;">denkt.</span></h2>
        <p class="reveal text-lg max-w-[580px] mx-auto leading-relaxed" style="color:#9999a1;">RAG-Architektur, semantische Vektoren und das Sokrates-Prinzip &mdash; gebaut für echtes Verstehen statt Durchklicken.</p>
      </div>

      <!-- RAG Pipeline -->
      <div class="reveal mb-14">
        <p class="text-xs font-semibold tracking-widest uppercase mb-5 text-center" style="color:#6e6e76;">Retrieval-Augmented Generation — so entsteht jede Antwort</p>
        <div style="overflow-x:auto;-webkit-overflow-scrolling:touch;">
          <div class="rag-pipeline" style="min-width:680px;">
            <div class="rag-step">
              <span class="rag-step__num">01</span>
              <div class="rag-step__icon" style="background:rgba(56,189,248,.1);">
                <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#38bdf8" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
              </div>
              <span class="rag-step__label">Deine Frage</span>
              <span class="rag-step__sub">Natürliche Sprache, kein spezielles Format nötig</span>
            </div>
            <div class="rag-step">
              <span class="rag-step__num">02</span>
              <div class="rag-step__icon" style="background:rgba(129,140,248,.1);">
                <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#818cf8" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="8" height="8" rx="1.5"/><rect x="14" y="3" width="8" height="8" rx="1.5"/><rect x="2" y="14" width="8" height="8" rx="1.5"/><path d="M18 14v6M15 17h6"/></svg>
              </div>
              <span class="rag-step__label">Embedding</span>
              <span class="rag-step__sub">3072-dim. Vektor via text-embedding-3-large</span>
            </div>
            <div class="rag-step">
              <span class="rag-step__num">03</span>
              <div class="rag-step__icon" style="background:rgba(14,165,233,.1);">
                <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#0ea5e9" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4-4"/><path d="M8 11h6M11 8v6"/></svg>
              </div>
              <span class="rag-step__label">pgvector-Suche</span>
              <span class="rag-step__sub">Kosinus ≥ 0,45 &mdash; nur passende Chunks</span>
            </div>
            <div class="rag-step">
              <span class="rag-step__num">04</span>
              <div class="rag-step__icon" style="background:rgba(56,189,248,.1);">
                <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#38bdf8" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
              </div>
              <span class="rag-step__label">Kursinhalt</span>
              <span class="rag-step__sub">Relevante Enabler &amp; Materialien als Kontext</span>
            </div>
            <div class="rag-step" style="background:rgba(56,189,248,.025);">
              <span class="rag-step__num" style="background:linear-gradient(135deg,#38bdf8,#818cf8);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;">05</span>
              <div class="rag-step__icon" style="background:linear-gradient(135deg,rgba(56,189,248,.12),rgba(129,140,248,.12));">
                <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#7dd3fc" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              </div>
              <span class="rag-step__label" style="background:linear-gradient(135deg,#38bdf8,#818cf8);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;">HAI antwortet</span>
              <span class="rag-step__sub">Leitfragen &mdash; keine fertigen Lösungen</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 3 Creative Cards -->
      <div class="reveal grid md:grid-cols-3 gap-6">

        <!-- Card 1: Sokrates-Methode -->
        <div class="hai2-card">
          <div class="flex items-center gap-3 mb-5">
            <div class="hai2-card-icon" style="background:rgba(56,189,248,.12);">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#38bdf8" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <h3 class="font-bold text-base" style="color:#f0f0f2;">Sokrates-Methode</h3>
          </div>
          <div class="flex flex-col gap-2 mb-4">
            <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:10px 10px 10px 2px;padding:9px 12px;font-size:.78rem;color:#b0b8c8;line-height:1.4;">Wie funktioniert ein LEFT JOIN?</div>
            <div style="background:rgba(56,189,248,.08);border:1px solid rgba(56,189,248,.14);border-radius:2px 10px 10px 10px;padding:9px 12px;font-size:.78rem;color:#93c5fd;line-height:1.4;">Was weißt du bereits über JOIN-Typen? Fang mit dem an, was dir bekannt ist.</div>
            <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:10px 10px 10px 2px;padding:9px 12px;font-size:.78rem;color:#b0b8c8;line-height:1.4;">Nur INNER JOIN kenn ich...</div>
            <div style="background:rgba(56,189,248,.08);border:1px solid rgba(56,189,248,.14);border-radius:2px 10px 10px 10px;padding:9px 12px;font-size:.78rem;color:#93c5fd;line-height:1.4;">Gut. Schau Enabler&nbsp;38 &mdash; beschreib dann den Unterschied zum LEFT JOIN.</div>
          </div>
          <p class="text-xs" style="color:#6e6e76;">HAI führt dich hin &mdash; gibt keine Lösungen direkt.</p>
        </div>

        <!-- Card 2: Quiz-Progression -->
        <div class="hai2-card">
          <div class="flex items-center gap-3 mb-5">
            <div class="hai2-card-icon" style="background:rgba(129,140,248,.12);">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#818cf8" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 4 12 14.01 9 11.01"/><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/></svg>
            </div>
            <h3 class="font-bold text-base" style="color:#f0f0f2;">Quiz-Progression</h3>
