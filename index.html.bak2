          </div>
          <div class="trust-row">
            <div class="trust-dot" style="background:rgba(248,113,113,.1);color:#f87171;">✗</div>
            <div>
              <div class="text-sm font-semibold mb-0.5" style="color:#e2e8f0;">Kein unkontrolliertes Internet</div>
              <div class="text-xs" style="color:#6e6e76;">Websuche ist optional &mdash; Standard ist Closed Context</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <div class="divider-gradient" style="background:linear-gradient(to bottom,#060e1b,var(--color-bg));"></div>

  <!-- ROI — Organic blobs, light -->
  <section class="py-24 md:py-36 section-organic" id="roi">
    <div class="max-w-[1100px] mx-auto px-5 md:px-10">
      <span class="reveal inline-block text-xs font-semibold tracking-widest uppercase text-accent bg-accent-soft px-3 py-1 rounded mb-4">Der Effekt</span>
      <h2 class="reveal text-3xl md:text-5xl font-bold leading-[1.1] tracking-tight mb-5">So entlastet LFA<br>Betrieb und Azubi.</h2>
      <p class="reveal text-lg text-muted max-w-[620px] leading-relaxed mb-12">Konkrete Zahlen, die zeigen, was LFA für Ausbildungsbetriebe und Auszubildende verändert.</p>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-5 items-stretch">
        <!-- Big featured stat — warning: this is a COST -->
        <div class="reveal md:col-span-2 relative p-10 rounded-2xl border border-border-hover overflow-hidden flex flex-col items-center justify-center text-center" style="background:linear-gradient(160deg,var(--color-surface-bright),var(--color-surface))">
          <div class="absolute top-0 left-0 right-0 h-[2px]" style="background:linear-gradient(90deg,transparent,var(--color-accent),transparent)"></div>
          <div class="w-12 h-12 rounded-full flex items-center justify-center mb-4" style="background:rgba(255,180,0,.12);border:1px solid rgba(255,180,0,.2);">
            <svg class="w-6 h-6" style="color:#e6a700;" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <div class="text-5xl md:text-6xl font-bold gradient-text leading-none mb-3 tabular-nums whitespace-nowrap" data-target="30000" data-separator="." data-suffix=" EUR">0</div>
          <span class="block text-lg font-medium mb-1">Kosten pro Ausbildungsabbruch</span>
          <span class="block text-sm text-faint mb-4">Direkte und indirekte Kosten für den Betrieb</span>
          <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold" style="background:rgba(255,26,26,.08);color:var(--color-accent);">LFA reduziert Abbrüche durch Struktur und Betreuung</span>
        </div>
        <!-- Two stacked stats — POSITIVE reductions -->
        <div class="md:col-span-3 grid grid-rows-2 gap-5">
          <div class="reveal relative p-8 rounded-2xl border border-border-hover overflow-hidden flex items-center gap-6" style="background:linear-gradient(160deg,var(--color-surface-bright),var(--color-surface))">
            <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background:rgba(40,200,64,.1);border:1px solid rgba(40,200,64,.2);">
              <svg class="w-5 h-5" style="color:#28c840;" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="7 13 12 18 17 13"/><line x1="12" y1="6" x2="12" y2="18"/></svg>
            </div>
            <div class="text-4xl md:text-5xl font-bold gradient-text leading-none tabular-nums shrink-0" data-target="40" data-suffix="%">0</div>
            <div class="text-left">
              <span class="block font-medium">weniger Papierkram</span>
              <span class="block text-sm text-faint mt-1">Berichtshefte, Zeugnisse und Berichte automatisch generiert</span>
            </div>
          </div>
          <div class="reveal relative p-8 rounded-2xl border border-border-hover overflow-hidden flex items-center gap-6" style="background:linear-gradient(160deg,var(--color-surface-bright),var(--color-surface))">
            <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background:rgba(40,200,64,.1);border:1px solid rgba(40,200,64,.2);">
              <svg class="w-5 h-5" style="color:#28c840;" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="7 13 12 18 17 13"/><line x1="12" y1="6" x2="12" y2="18"/></svg>
            </div>
            <div class="text-4xl md:text-5xl font-bold gradient-text leading-none tabular-nums shrink-0" data-target="60" data-suffix="%">0</div>
            <div class="text-left">
              <span class="block font-medium">weniger private Lernzeit nötig</span>
              <span class="block text-sm text-faint mt-1">Gezielte Vorbereitung auf IHK-Prüfungen statt blindes Büffeln</span>
            </div>
          </div>
        </div>
      </div>
      <!-- Summary callout -->
      <div class="reveal mt-8 p-6 rounded-2xl text-center" style="background:rgba(40,200,64,.04);border:1px solid rgba(40,200,64,.12);">
        <p class="text-sm font-medium" style="color:#1a8f2d;">Zusammengefasst: LFA spart dem Betrieb Geld, reduziert Verwaltungsaufwand und gibt Azubis effektivere Lernzeit zurück.</p>
      </div>
    </div>
  </section>


  <!-- ARCHITEKTUR — Subtle alt bg with glow -->
  <section class="py-24 md:py-36 section-alt section-glow" id="architektur">
    <div class="max-w-[1100px] mx-auto px-5 md:px-10">
      <span
        class="reveal inline-block text-xs font-semibold tracking-widest uppercase text-accent bg-accent-soft px-3 py-1 rounded mb-4">Technologie
        und Vertrauen</span>
      <h2 class="reveal text-3xl md:text-5xl font-bold leading-[1.1] tracking-tight mb-5">Sicher, schnell und<br>durchdacht gebaut.
      </h2>
      <p class="reveal text-lg text-muted max-w-[620px] leading-relaxed">Moderne Technologie, die zuverlässig funktioniert — und deine Daten schützt.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-14">
        <div class="reveal p-7 rounded-2xl bg-surface border border-border card-hover accent-hover tilt-card">
          <div
            class="w-11 h-11 rounded-xl bg-accent-soft border border-border-accent flex items-center justify-center mb-5 text-accent">
            <svg class="icon">
              <use href="#i-shield" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">KI, die keine Fakten erfindet</h3>
          <p class="text-sm text-muted leading-relaxed">Unsere KI antwortet nur mit Wissen aus echten IHK-Büchern und Firmendaten. Eingebaute Regeln verhindern, dass sie sich Antworten ausdenkt.</p>
        </div>
        <div class="reveal p-7 rounded-2xl bg-surface border border-border card-hover accent-hover tilt-card">
          <div
            class="w-11 h-11 rounded-xl bg-accent-soft border border-border-accent flex items-center justify-center mb-5 text-accent">
            <svg class="icon">
              <use href="#i-lock" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Deine Daten sind geschützt</h3>
          <p class="text-sm text-muted leading-relaxed">Jeder Nutzer sieht nur das, was er sehen darf. Alle Daten werden verschlüsselt, in der EU gespeichert und nach DSGVO-Standards verarbeitet.</p>
        </div>
        <div class="reveal p-7 rounded-2xl bg-surface border border-border card-hover accent-hover tilt-card">
          <div
            class="w-11 h-11 rounded-xl bg-accent-soft border border-border-accent flex items-center justify-center mb-5 text-accent">
            <svg class="icon">
              <use href="#i-zap" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Blitzschnelle Ladezeiten</h3>
          <p class="text-sm text-muted leading-relaxed">Fünf Ebenen intelligentes Caching sorgen dafür, dass Seiten sofort laden — egal ob im Büro oder unterwegs.</p>
        </div>
      </div>
      <div class="marquee reveal mt-10">
        <div class="marquee__track">
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-muted whitespace-nowrap">Next.js 15</span>
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-muted whitespace-nowrap">TypeScript</span>
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-muted whitespace-nowrap">React 18</span>
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-muted whitespace-nowrap">PostgreSQL</span>
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-muted whitespace-nowrap">pgvector</span>
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-muted whitespace-nowrap">Drizzle ORM</span>
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-muted whitespace-nowrap">Supabase Auth</span>
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-muted whitespace-nowrap">Gemini AI</span>
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-muted whitespace-nowrap">Vercel Edge</span>
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-muted whitespace-nowrap">Next.js 15</span>
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-muted whitespace-nowrap">TypeScript</span>
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-muted whitespace-nowrap">React 18</span>
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-muted whitespace-nowrap">PostgreSQL</span>
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-muted whitespace-nowrap">pgvector</span>
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-muted whitespace-nowrap">Drizzle ORM</span>
          <span class="px-4 py-2 rounded-full text-sm font-medium bg-surface border border-border text-muted whitespace-nowrap">Supabase Auth</span>
