  <!-- SOLAR SYSTEM — Lernuniversum -->
  <section class="section-dark" id="solarsystem" style="position:relative;overflow:hidden;">
    <div class="max-w-[1100px] mx-auto px-5 md:px-10 text-center pt-24 md:pt-36 pb-8">
      <span class="reveal inline-block text-xs font-semibold tracking-widest uppercase text-accent bg-accent-soft px-3 py-1 rounded mb-4">Inhaltsarchitektur</span>
      <h2 class="reveal text-3xl md:text-5xl font-bold leading-[1.1] tracking-tight mb-5" style="color:#f0f0f2;">Vom Chaos &#x2192; zur Klarheit.</h2>
      <p class="reveal text-lg max-w-[560px] mx-auto leading-relaxed mb-10" style="color:#9999a1;">Klicke auf <strong style="color:#ff6060;">FIAE</strong> und fliege durch das gesamte Lernuniversum &mdash; Lernfelder, Komponenten und Use Cases.</p>

      <!-- Begriffserklärung -->
      <div class="reveal flex flex-wrap justify-center gap-3 md:gap-5 mb-2">
