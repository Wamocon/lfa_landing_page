            </div>
            <span class="text-xs font-semibold" style="color:#34d399;flex-shrink:0;">✓ Bestanden</span>
          </div>
          <div class="quiz-level quiz-level--active">
            <div style="flex:1;">
              <div class="text-xs font-bold mb-1.5" style="color:#38bdf8;">MITTEL</div>
