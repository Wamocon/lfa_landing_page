<!DOCTYPE html>
<html lang="de" class="scroll-smooth">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LFA — Lernplattform für Azubis | KI-gestützte duale IT-Ausbildung</title>
  <meta name="description"
    content="Die KI-gesteuerte Plattform für die duale IT-Ausbildung. Closed-Context KI, IHK-konform, sofortiges Feedback für Fachinformatiker.">
  <meta name="theme-color" content="#f5f5f7">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <script src="galaxy_data_compact.js"></script>
  <style type="text/tailwindcss">
    @theme {
      --color-bg: #f5f5f7;
      --color-bg-alt: #eeeef0;
      --color-surface: #ffffff;
      --color-surface-hover: #f8f8fa;
      --color-surface-bright: #ffffff;
      --color-border: rgba(0,0,0,.08);
      --color-border-hover: rgba(0,0,0,.14);
      --color-border-accent: rgba(255,26,26,.18);
      --color-accent: #e01515;
      --color-accent-dim: #c01010;
      --color-accent-soft: rgba(255,26,26,.06);
      --color-accent-glow: rgba(255,26,26,.12);
      --color-text-main: #111113;
      --color-muted: #555558;
      --color-faint: #8e8e93;
      --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
    }
    html { scrollbar-gutter: auto; }
    body { font-family: var(--font-sans); background: var(--color-bg); color: var(--color-text-main); position: relative; }
    /* Animated Gradient Orbs */
    .gradient-orbs { position:fixed; inset:0; z-index:0; pointer-events:none; overflow:hidden; }
    .orb { position:absolute; border-radius:50%; filter:blur(100px); will-change:transform; }
    .orb--1 { width:600px; height:600px; background:#e01515; opacity:.04; top:5%; left:10%; animation:orb-drift-1 25s ease-in-out infinite; }
    .orb--2 { width:500px; height:500px; background:#6432b4; opacity:.035; top:40%; right:5%; animation:orb-drift-2 30s ease-in-out infinite; }
    .orb--3 { width:450px; height:450px; background:#e01515; opacity:.03; bottom:15%; left:50%; animation:orb-drift-3 22s ease-in-out infinite; }
    @keyframes orb-drift-1 { 0%,100%{transform:translate(0,0) scale(1)} 33%{transform:translate(80px,-50px) scale(1.15)} 66%{transform:translate(-40px,60px) scale(.9)} }
    @keyframes orb-drift-2 { 0%,100%{transform:translate(0,0) scale(1)} 40%{transform:translate(-60px,40px) scale(1.1)} 70%{transform:translate(50px,-70px) scale(.85)} }
    @keyframes orb-drift-3 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(-80px,-50px) scale(1.2)} }
    ::selection { background: var(--color-accent); color:#fff; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.7)} }
    .nav-scrolled { background:rgba(255,255,255,.82)!important; backdrop-filter:saturate(180%) blur(20px); -webkit-backdrop-filter:saturate(180%) blur(20px); border-bottom:1px solid rgba(255,26,26,.08); }
    .gradient-text { background:linear-gradient(135deg,var(--color-accent),#ff6b6b); -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; }
    .card-hover { transition: border-color .7s cubic-bezier(.16,1,.3,1), transform .7s cubic-bezier(.16,1,.3,1), box-shadow .7s cubic-bezier(.16,1,.3,1); }
    .card-hover:hover { border-color:var(--color-border-hover); transform:translateY(-3px); box-shadow:0 16px 48px rgba(0,0,0,.08),0 0 0 1px rgba(255,26,26,.04); }
    .tilt-card { transform-style:preserve-3d; }
    .accent-hover:hover { border-color:var(--color-border-accent)!important; box-shadow:0 16px 48px rgba(0,0,0,.08),0 0 30px rgba(255,26,26,.05)!important; }
    .accent-hover { position:relative; }
    .accent-hover::before { content:''; position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,rgba(255,26,26,.3),transparent); opacity:0; transition:opacity .5s ease; }
    .accent-hover:hover::before { opacity:1; }
    .reveal { opacity:0; transform:translateY(30px); transition:opacity .8s cubic-bezier(.16,1,.3,1),transform .8s cubic-bezier(.16,1,.3,1); }
    .reveal--visible { opacity:1; transform:translateY(0); }
    .faq-answer { max-height:0; overflow:hidden; transition:max-height .55s cubic-bezier(.25,0,.3,1); }
    .faq-item--open .faq-answer { max-height:400px; transition:max-height .5s cubic-bezier(.16,1,.3,1); }
    .faq-item--open { border-color:rgba(255,26,26,.15)!important; box-shadow:0 4px 24px rgba(255,26,26,.04); }
    .faq-question__icon::before,.faq-question__icon::after { content:''; position:absolute; background:var(--color-muted); border-radius:2px; transition:transform .4s cubic-bezier(.16,1,.3,1); }
    .faq-question__icon::before { width:14px; height:2px; top:50%; left:50%; transform:translate(-50%,-50%); }
    .faq-question__icon::after { width:2px; height:14px; top:50%; left:50%; transform:translate(-50%,-50%); }
    .faq-item--open .faq-question__icon::after { transform:translate(-50%,-50%) rotate(90deg); opacity:0; }
    /* ── Tech Stack Marquee ── */
    .marquee { overflow:hidden; -webkit-mask-image:linear-gradient(90deg,transparent,#000 8%,#000 92%,transparent); mask-image:linear-gradient(90deg,transparent,#000 8%,#000 92%,transparent); }
    .marquee__track { display:flex; gap:12px; width:max-content; animation:marquee-scroll 30s linear infinite; }
    .marquee:hover .marquee__track { animation-play-state:paused; }
    @keyframes marquee-scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
    /* ── Mobile hamburger nav ── */
    .nav-hamburger { display:none; flex-direction:column; justify-content:center; gap:5px; cursor:pointer; padding:8px; border:none; background:transparent; z-index:51; -webkit-tap-highlight-color:transparent; }
    @media (max-width: 767px) { .nav-hamburger { display:flex; } }
    .nav-hamburger span { display:block; width:22px; height:2px; background:var(--color-text-main); border-radius:2px; transition:transform .35s cubic-bezier(.16,1,.3,1), opacity .25s ease; }
    .nav-hamburger.is-open span:nth-child(1) { transform:translateY(7px) rotate(45deg); }
    .nav-hamburger.is-open span:nth-child(2) { opacity:0; transform:translateX(-6px); }
    .nav-hamburger.is-open span:nth-child(3) { transform:translateY(-7px) rotate(-45deg); }
    #mobileMenu { display:none; position:fixed; inset:0; z-index:50; flex-direction:column; align-items:center; justify-content:center; gap:0; background:rgba(245,245,247,.97); backdrop-filter:saturate(180%) blur(24px); -webkit-backdrop-filter:saturate(180%) blur(24px); }
    #mobileMenu.is-open { display:flex; }
    .mm-link { font-size:1.65rem; font-weight:700; color:var(--color-text-main); text-decoration:none; padding:14px 32px; letter-spacing:-.02em; transition:color .2s ease, transform .2s ease; }
    .mm-link:hover { color:var(--color-accent); transform:translateX(4px); }
    .mm-divider { width:40px; height:1px; background:var(--color-border); margin:4px 0; }

    /* ── Magnetic Button ── */
    .magnetic-btn { position:relative; display:inline-block; transition:transform .3s cubic-bezier(.16,1,.3,1); }

    /* ── Typing Animation ── */
    .typing-cursor { display:inline-block; width:3px; height:.75em; background:var(--color-accent); margin-left:2px; vertical-align:baseline; -webkit-text-fill-color:initial; animation:blink-cursor .7s step-end infinite; }
    @keyframes blink-cursor { 0%,100%{opacity:1} 50%{opacity:0} }

    /* ── Gradient Border Animation ── */
    .gradient-border { position:relative; }
    .gradient-border::after { content:''; position:absolute; inset:-1px; border-radius:inherit; padding:1px; background:conic-gradient(from var(--border-angle,0deg),transparent 40%,rgba(255,26,26,.4) 50%,transparent 60%); -webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0); mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0); -webkit-mask-composite:xor; mask-composite:exclude; opacity:0; transition:opacity .5s ease; pointer-events:none; animation:rotate-border 4s linear infinite; }
    .gradient-border:hover::after { opacity:1; }
    @keyframes rotate-border { 0%{--border-angle:0deg} 100%{--border-angle:360deg} }
    @property --border-angle { syntax:'<angle>'; initial-value:0deg; inherits:false; }

    /* ── Bento Grid Enhancements ── */
    .bento-featured { position:relative; overflow:hidden; }
    .bento-featured::before { content:''; position:absolute; inset:0; background-image:radial-gradient(circle, rgba(255,26,26,.06) 1px, transparent 1px); background-size:24px 24px; opacity:0; transition:opacity .5s ease; pointer-events:none; }
    .bento-featured:hover::before { opacity:1; }
    .bento-featured:hover { border-color:var(--color-border-accent)!important; box-shadow:0 20px 60px rgba(0,0,0,.1), 0 0 40px rgba(255,26,26,.06)!important; }

    /* ── Cookie Consent ── */
    .cookie-banner { position:fixed; bottom:0; left:0; right:0; z-index:9998; transform:translateY(100%); transition:transform .5s cubic-bezier(.16,1,.3,1); }
    .cookie-banner--visible { transform:translateY(0); }
    .cookie-banner__inner { max-width:680px; margin:0 auto 24px; padding:24px 28px; background:rgba(255,255,255,.95); backdrop-filter:saturate(180%) blur(20px); -webkit-backdrop-filter:saturate(180%) blur(20px); border-radius:20px; border:1px solid rgba(0,0,0,.08); box-shadow:0 20px 60px rgba(0,0,0,.12),0 0 0 1px rgba(0,0,0,.03); }
    .cookie-banner__title { font-weight:700; font-size:.95rem; margin-bottom:6px; }
    .cookie-banner__text { font-size:.8rem; color:var(--color-muted); line-height:1.6; margin-bottom:16px; }
    .cookie-banner__text a { color:var(--color-accent); text-decoration:underline; text-underline-offset:2px; }
    .cookie-banner__actions { display:flex; gap:10px; flex-wrap:wrap; }
    .cookie-banner__btn { padding:10px 22px; border-radius:10px; font-size:.8rem; font-weight:600; cursor:pointer; transition:all .25s ease; border:none; }
    .cookie-banner__btn--accept { background:var(--color-accent); color:#fff; }
    .cookie-banner__btn--accept:hover { background:var(--color-accent-dim); transform:translateY(-1px); box-shadow:0 4px 16px rgba(224,21,21,.25); }
    .cookie-banner__btn--reject { background:var(--color-bg-alt); color:var(--color-text-main); border:1px solid var(--color-border); }
    .cookie-banner__btn--reject:hover { background:var(--color-bg); border-color:var(--color-border-hover); }
    .cookie-banner__btn--settings { background:transparent; color:var(--color-muted); font-weight:500; padding:10px 14px; }
    .cookie-banner__btn--settings:hover { color:var(--color-text-main); }
    /* ── Image Placeholders ── */
    .img-placeholder { border:2px dashed rgba(0,0,0,.12); border-radius:16px; background:rgba(0,0,0,.02); display:flex; flex-direction:column; align-items:center; justify-content:center; padding:32px; color:var(--color-faint); gap:8px; }
    .img-placeholder svg { width:40px; height:40px; opacity:.3; stroke:currentColor; fill:none; stroke-width:1.5; stroke-linecap:round; stroke-linejoin:round; }
    /* ── Lightbox ── */
    .lightbox-wrap { position:relative; cursor:pointer; }
    .lightbox-wrap::after { content:''; position:absolute; inset:0; border-radius:12px; background:rgba(0,0,0,0); transition:background .25s ease; pointer-events:none; }
    .lightbox-wrap:hover::after { background:rgba(0,0,0,.06); }
    .lightbox-hint { position:absolute; bottom:8px; right:8px; width:28px; height:28px; display:flex; align-items:center; justify-content:center; border-radius:7px; background:rgba(0,0,0,.45); backdrop-filter:blur(6px); color:rgba(255,255,255,.9); opacity:0; transform:translateY(4px); transition:all .25s cubic-bezier(.16,1,.3,1); z-index:2; pointer-events:none; }
    .lightbox-hint svg { width:14px; height:14px; }
    .lightbox-wrap:hover .lightbox-hint { opacity:1; transform:translateY(0); }
    .lightbox { position:fixed; inset:0; z-index:9999; display:none; align-items:center; justify-content:center; }
    .lightbox--active { display:flex; }
    .lightbox::before { content:''; position:absolute; inset:0; background:rgba(0,0,0,.6); backdrop-filter:blur(12px); opacity:0; transition:opacity .35s ease; }
    .lightbox--active::before { opacity:1; }
    .lightbox--closing::before { opacity:0; transition:opacity .3s ease; }
    .lightbox__close { position:absolute; top:16px; right:16px; width:36px; height:36px; border-radius:50%; background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.12); color:#fff; display:flex; align-items:center; justify-content:center; cursor:pointer; z-index:10; opacity:0; transform:scale(.5); transition:all .35s cubic-bezier(.16,1,.3,1) .1s; }
    .lightbox--active .lightbox__close { opacity:1; transform:scale(1); }
    .lightbox--closing .lightbox__close { opacity:0; transform:scale(.5); transition:all .2s ease; }
    .lightbox__close:hover { background:rgba(255,255,255,.2); border-color:rgba(255,255,255,.25); }
    .lightbox__close svg { width:18px; height:18px; }
    .lightbox__img { position:fixed; z-index:5; box-shadow:0 16px 50px rgba(0,0,0,.35); }
    /* ── Immersive Roadmap ── */
    .rm { position:relative; max-width:940px; margin:0 auto; padding:60px 0 40px; }
    .rm__line { position:absolute; left:50%; top:0; bottom:0; width:120px; transform:translateX(-50%); overflow:visible; pointer-events:none; }
    .rm__line svg { position:absolute; top:0; left:50%; transform:translateX(-50%); width:120px; height:100%; }
    .rm__line-bg { fill:none; stroke:rgba(255,255,255,.1); stroke-width:3; stroke-linecap:round; }
    .rm__line-progress { fill:none; stroke:url(#rmGradient); stroke-width:3; stroke-linecap:round; }
    .rm__line-glow { position:absolute; left:50%; width:23px; height:40px; border-radius:50%; background:radial-gradient(circle,rgba(255,26,26,.7),transparent 70%); filter:blur(8px); top:0; pointer-events:none; z-index:1; opacity:0; transform:translateX(-50%); }
    .rm__row { display:grid; grid-template-columns:1fr 80px 1fr; position:relative; }
    .rm__row + .rm__row { margin-top:48px; }
    .rm__center { display:flex; justify-content:center; position:relative; padding-top:20px; }
    .rm__dot { width:18px; height:18px; border-radius:50%; background:rgba(255,255,255,.08); border:3px solid rgba(255,255,255,.15); position:relative; z-index:3; transition:all .6s cubic-bezier(.16,1,.3,1); flex-shrink:0; }
    .rm__dot--active { background:var(--color-accent); border-color:var(--color-accent); box-shadow:0 0 20px rgba(255,26,26,.55),0 0 40px rgba(255,26,26,.18); transform:scale(1.4); }
    .rm__dot--active::after { content:''; position:absolute; inset:-8px; border-radius:50%; border:2px solid rgba(255,26,26,.3); animation:rm-pulse 2s ease-out infinite; }
    @keyframes rm-pulse { 0%{transform:scale(.8);opacity:.7} 100%{transform:scale(1.8);opacity:0} }
    .rm__branch { position:absolute; top:28px; height:2px; background:rgba(255,255,255,.1); transition:background .6s ease,box-shadow .6s ease; border-radius:1px; }
    .rm__branch--l { right:calc(50% + 9px); left:0; }
    .rm__branch--r { left:calc(50% + 9px); right:0; }
    .rm__branch--active { background:var(--color-accent); box-shadow:0 0 10px rgba(255,26,26,.3); }
    .rm__card { padding:28px; border-radius:16px; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.08); opacity:0; transition:opacity .7s cubic-bezier(.16,1,.3,1),transform .7s cubic-bezier(.16,1,.3,1),border-color .5s ease,box-shadow .5s ease; }
    .rm__card--l { transform:translateX(-40px); text-align:right; }
    .rm__card--r { transform:translateX(40px); }
    .rm__card--active { opacity:1!important; transform:translateX(0)!important; border-color:rgba(255,26,26,.2); box-shadow:0 8px 32px rgba(0,0,0,.3),0 0 30px rgba(255,26,26,.06); }
    .rm__label { display:inline-block; font-size:11px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--color-accent); background:rgba(255,26,26,.1); padding:3px 10px; border-radius:6px; margin-bottom:10px; }
    .rm__title { font-size:1.2rem; font-weight:700; margin-bottom:6px; letter-spacing:-.01em; color:#f0f0f2; }
    .rm__desc { font-size:.875rem; color:#9999a1; line-height:1.7; margin-bottom:14px; }
    .rm__tags { display:flex; flex-wrap:wrap; gap:6px; }
    .rm__card--l .rm__tags { justify-content:flex-end; }
    .rm__tag { font-size:11px; padding:3px 10px; border-radius:20px; background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1); color:#8e8e96; font-weight:500; }
    @media (max-width:767px) {
      .rm__row { grid-template-columns:40px 1fr; }
      .rm__center { padding-top:4px; }
      .rm__line { left:20px; }
      .rm__card--l,.rm__card--r { text-align:left; transform:translateX(20px); grid-column:2; }
      .rm__card--l .rm__tags { justify-content:flex-start; }
      .rm__cell--hide { display:none; }
      .rm__branch { display:none; }
    }
    .rm__end { display:flex; justify-content:center; padding-top:64px; position:relative; z-index:3; }
    .rm__end-marker { display:flex; flex-direction:column; align-items:center; gap:12px; opacity:0; transform:translateY(20px); transition:all .7s cubic-bezier(.16,1,.3,1); }
    .rm__end-marker--active { opacity:1; transform:translateY(0); }
    .rm__end-ring { width:48px; height:48px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:rgba(255,255,255,.06); border:2px solid rgba(255,255,255,.12); transition:all .7s cubic-bezier(.16,1,.3,1); }
    .rm__end-marker--active .rm__end-ring { background:linear-gradient(135deg,var(--color-accent),#ff6b6b); border-color:transparent; box-shadow:0 0 30px rgba(255,26,26,.5),0 0 60px rgba(255,26,26,.15); }
    .rm__end-ring svg { color:rgba(255,255,255,.2); transition:color .6s ease; }
    .rm__end-marker--active .rm__end-ring svg { color:#fff; }
    .rm__end-label { font-size:.875rem; font-weight:600; color:rgba(255,255,255,.15); transition:color .7s ease; letter-spacing:.02em; }
    .rm__end-marker--active .rm__end-label { color:#f0f0f2; }
    /* ── Solar System ── */
    .solar-wrap { position:relative; width:100%; height:520px; }
    @media (max-width:767px) { .solar-wrap { height:380px; } }
    #solarCanvas { position:absolute; inset:0; width:100%; height:100%; display:block; }
    /* ── Galaxy Overlay ── */
    #galaxyOverlay { position:fixed; inset:0; z-index:9500; background:#040810; display:none; flex-direction:column; }
    #galaxyOverlay.go--open { display:flex; }
    #galaxyBack { position:absolute; top:18px; left:18px; z-index:20; background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.14); color:#e2e8f0; font-size:.78rem; font-weight:600; padding:7px 16px; border-radius:10px; cursor:pointer; transition:background .2s; font-family:inherit; }
    #galaxyBack:hover { background:rgba(255,255,255,.15); }
    #galaxyTitle { position:absolute; top:21px; left:50%; transform:translateX(-50%); font-size:.78rem; font-weight:700; color:#888; letter-spacing:.08em; text-transform:uppercase; white-space:nowrap; pointer-events:none; }
    #galaxyLegend { position:absolute; top:16px; right:18px; z-index:20; display:flex; gap:14px; align-items:center; }
    .glgd { display:flex; align-items:center; gap:7px; cursor:default; }
    .glgd-dot { border-radius:50%; flex-shrink:0; }
    #galaxySvgContainer { width:100%; height:100%; }
    #galaxySvgContainer svg { display:block; }
    #galaxyTooltip { position:fixed; z-index:9600; background:rgba(4,8,16,.95); border:1px solid rgba(56,189,248,.22); border-radius:10px; padding:10px 14px; font-size:.74rem; color:#e2e8f0; pointer-events:none; display:none; max-width:300px; line-height:1.55; box-shadow:0 8px 32px rgba(0,0,0,.6); }
    #galaxySearch { position:fixed; bottom:22px; left:50%; transform:translateX(-50%); z-index:9600; background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.12); border-radius:12px; padding:9px 18px; color:#e2e8f0; font-size:.8rem; width:240px; outline:none; font-family:inherit; }
    #galaxySearch:focus { border-color:rgba(56,189,248,.5); background:rgba(255,255,255,.1); }
    #galaxySearch::placeholder { color:#6e6e76; }
    /* ── Zoom layer ── */
    #zoomLayer { position:fixed; inset:0; z-index:9400; pointer-events:none; display:none; overflow:hidden; }
    #zoomCircle { position:absolute; border-radius:50%; background:#040810; }
    /* ── HAI Section ── */
    .section-hai { background:#09111f; color:#f0f0f2; position:relative; overflow:hidden; }
    .section-hai::before { content:''; position:absolute; top:0; left:50%; transform:translateX(-50%); width:800px; height:500px; background:radial-gradient(ellipse at 50% 0%, rgba(14,165,233,.07) 0%, transparent 65%); pointer-events:none; z-index:0; }
    .hai-demo-card { background:rgba(255,255,255,.03); border:1px solid rgba(56,189,248,.15); border-radius:18px; padding:24px; display:flex; flex-direction:column; gap:14px; width:100%; max-width:420px; box-shadow:0 0 40px rgba(14,165,233,.06), 0 8px 24px rgba(0,0,0,.3); }
    .hai-bubble { border-radius:12px; padding:12px 16px; font-size:.875rem; line-height:1.55; }
    .hai-bubble--bot { background:rgba(56,189,248,.08); border:1px solid rgba(56,189,248,.15); color:#e2e8f0; border-top-left-radius:4px; }
    .hai-bubble--bot strong { color:#38bdf8; }
    .hai-bubble--user { background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.08); color:#b0b0b8; text-align:right; border-top-right-radius:4px; align-self:flex-end; max-width:80%; }
    .hai-feature { display:flex; gap:14px; align-items:flex-start; }
    .hai-feature-icon { width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .hai-stat { background:rgba(255,255,255,.03); border:1px solid rgba(56,189,248,.12); border-radius:14px; padding:18px 20px; display:flex; flex-direction:column; gap:4px; }
    .hai-stat-num { font-size:1.5rem; font-weight:800; letter-spacing:-.02em; background:linear-gradient(135deg,#38bdf8,#7dd3fc); -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; line-height:1.1; }
    .hai-stat-label { font-size:.7rem; font-weight:700; letter-spacing:.06em; text-transform:uppercase; color:#38bdf8; }
    .hai-stat-sub { font-size:.72rem; color:#6e6e76; line-height:1.4; }
    /* ── HAI Deep Section ── */
    .section-hai-deep { background:#060e1b; background-image:radial-gradient(rgba(56,189,248,.07) 1px, transparent 1px); background-size:36px 36px; color:#f0f0f2; position:relative; overflow:hidden; }
    .section-hai-deep::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse 60% 50% at 10% 80%, rgba(56,189,248,.07) 0%, transparent 60%), radial-gradient(ellipse 50% 60% at 90% 20%, rgba(129,140,248,.06) 0%, transparent 60%); pointer-events:none; }
    .rag-pipeline { display:flex; border:1px solid rgba(56,189,248,.12); border-radius:18px; overflow:hidden; }
    .rag-step { flex:1; display:flex; flex-direction:column; align-items:center; gap:8px; padding:22px 14px; border-right:1px solid rgba(56,189,248,.1); text-align:center; transition:background .3s; }
    .rag-step:last-child { border-right:none; }
    .rag-step:hover { background:rgba(56,189,248,.05); }
    .rag-step__num { font-size:.6rem; font-weight:800; letter-spacing:.1em; text-transform:uppercase; color:#38bdf8; }
    .rag-step__icon { width:46px; height:46px; border-radius:12px; display:flex; align-items:center; justify-content:center; }
    .rag-step__label { font-size:.8rem; font-weight:700; color:#e2e8f0; }
    .rag-step__sub { font-size:.65rem; color:#6e6e76; line-height:1.45; }
    .hai2-card { background:rgba(255,255,255,.02); border:1px solid rgba(56,189,248,.1); border-radius:20px; padding:28px 24px; position:relative; overflow:hidden; transition:border-color .4s, box-shadow .4s; }
    .hai2-card:hover { border-color:rgba(56,189,248,.22); box-shadow:0 8px 40px rgba(0,0,0,.3), 0 0 40px rgba(56,189,248,.06); }
    .hai2-card::after { content:''; position:absolute; top:0; left:15%; right:15%; height:1px; background:linear-gradient(90deg, transparent, rgba(56,189,248,.45), transparent); }
    .hai2-card-icon { width:40px; height:40px; border-radius:11px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .quiz-level { display:flex; align-items:center; gap:12px; padding:11px 14px; border-radius:10px; margin-bottom:8px; }
    .quiz-level--done { background:rgba(52,211,153,.06); border:1px solid rgba(52,211,153,.2); }
    .quiz-level--active { background:rgba(56,189,248,.06); border:1px solid rgba(56,189,248,.2); }
    .quiz-level--locked { background:rgba(255,255,255,.02); border:1px solid rgba(255,255,255,.06); }
    .quiz-bar { flex:1; height:4px; border-radius:2px; background:rgba(255,255,255,.06); overflow:hidden; }
    .quiz-bar__fill { height:100%; border-radius:2px; }
    .trust-row { display:flex; align-items:flex-start; gap:10px; padding:10px 0; border-bottom:1px solid rgba(255,255,255,.04); }
    .trust-row:last-child { border-bottom:none; }
    .trust-dot { width:22px; height:22px; border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:.65rem; font-weight:800; margin-top:1px; }
    .icon { width:24px; height:24px; fill:none; stroke:currentColor; stroke-width:1.5; stroke-linecap:round; stroke-linejoin:round; }
    .logo-img { filter:invert(1); }
    .hero-grid { opacity:.06!important; }
    /* ── Section Transitions — each unique ── */
    section { background:var(--color-bg); position:relative; z-index:1; }
    .section-alt { background:var(--color-bg-alt); }

    /* Gradient transition divider */
    .divider-gradient { height:120px; position:relative; z-index:2; pointer-events:none; margin-top:-1px; margin-bottom:-1px; }

    /* Dark premium section */
    .section-dark { background:#0f0f11; color:#f0f0f2; }
    .section-dark .text-muted { color:#9999a1; }
    .section-dark .text-faint { color:#6e6e76; }
    .section-dark h2,.section-dark h3 { color:#f0f0f2; }
    .section-dark .card-hover { background:rgba(255,255,255,.04); border-color:rgba(255,255,255,.08); }
    .section-dark .card-hover:hover { border-color:rgba(255,26,26,.25); box-shadow:0 16px 48px rgba(0,0,0,.3),0 0 30px rgba(255,26,26,.08); }
    .section-dark .accent-hover::before { background:linear-gradient(90deg,transparent,rgba(255,26,26,.5),transparent); }

    /* Glowing accent section */
    .section-glow { position:relative; overflow:hidden; }
    .section-glow::before { content:''; position:absolute; top:0; left:50%; transform:translateX(-50%); width:800px; height:600px; background:radial-gradient(circle,rgba(255,26,26,.06) 0%,transparent 60%); pointer-events:none; }

    /* Organic blob background */
    .section-organic { position:relative; overflow:hidden; }
    .section-organic::before { content:''; position:absolute; top:5%; right:0; width:50%; height:90%; background:radial-gradient(ellipse,rgba(255,26,26,.03) 0%,transparent 60%); border-radius:50%; pointer-events:none; transform:rotate(-15deg); }
    .section-organic::after { content:''; position:absolute; bottom:5%; left:0; width:45%; height:80%; background:radial-gradient(ellipse,rgba(100,50,180,.02) 0%,transparent 60%); border-radius:50%; pointer-events:none; transform:rotate(10deg); }
    .browser-chrome { border-radius:12px; overflow:hidden; border:1px solid var(--color-border-hover); box-shadow:0 20px 60px rgba(0,0,0,.1); }
    .browser-toolbar { display:flex; align-items:center; gap:10px; padding:10px 14px; background:var(--color-surface); border-bottom:1px solid var(--color-border); }
    .browser-dots { display:flex; gap:6px; }
    .browser-dots span { width:10px; height:10px; border-radius:50%; }
    .browser-dots span:nth-child(1) { background:#ff5f57; }
    .browser-dots span:nth-child(2) { background:#febc2e; }
    .browser-dots span:nth-child(3) { background:#28c840; }
    .browser-url { flex:1; padding:5px 12px; border-radius:6px; background:var(--color-bg); border:1px solid var(--color-border); font-size:11px; color:var(--color-faint); font-family:var(--font-sans); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  </style>
</head>

<body class="overflow-x-hidden antialiased leading-relaxed">

  <!-- Gradient Orbs -->
  <div class="gradient-orbs" aria-hidden="true">
    <div class="orb orb--1"></div>
    <div class="orb orb--2"></div>
    <div class="orb orb--3"></div>
  </div>

  <!-- SVG Sprite -->
  <svg class="hidden" xmlns="http://www.w3.org/2000/svg">
    <symbol id="i-shield" viewBox="0 0 24 24">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
    </symbol>
    <symbol id="i-zap" viewBox="0 0 24 24">
      <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
    </symbol>
    <symbol id="i-clipboard" viewBox="0 0 24 24">
      <path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2" />
      <rect x="8" y="2" width="8" height="4" rx="1" />
    </symbol>
    <symbol id="i-link" viewBox="0 0 24 24">
      <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71" />
      <path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71" />
    </symbol>
    <symbol id="i-clock" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="10" />
      <polyline points="12 6 12 12 16 14" />
    </symbol>
    <symbol id="i-building" viewBox="0 0 24 24">
      <rect x="4" y="2" width="16" height="20" rx="2" />
      <path d="M9 22v-4h6v4" />
      <path d="M8 6h.01M16 6h.01M8 10h.01M16 10h.01M8 14h.01M16 14h.01" />
    </symbol>
    <symbol id="i-book" viewBox="0 0 24 24">
      <path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" />
      <path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" />
    </symbol>
    <symbol id="i-help" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="10" />
      <path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3" />
      <line x1="12" y1="17" x2="12.01" y2="17" />
    </symbol>
    <symbol id="i-file" viewBox="0 0 24 24">
      <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
      <polyline points="14 2 14 8 20 8" />
      <line x1="16" y1="13" x2="8" y2="13" />
      <line x1="16" y1="17" x2="8" y2="17" />
    </symbol>
    <symbol id="i-chart" viewBox="0 0 24 24">
      <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
    </symbol>
    <symbol id="i-check" viewBox="0 0 24 24">
      <path d="M22 11.08V12a10 10 0 11-5.93-9.14" />
      <polyline points="22 4 12 14.01 9 11.01" />
    </symbol>
    <symbol id="i-bot" viewBox="0 0 24 24">
      <rect x="3" y="11" width="18" height="10" rx="2" />
      <circle cx="12" cy="5" r="2" />
      <path d="M12 7v4" />
      <line x1="8" y1="16" x2="8" y2="16" />
      <line x1="16" y1="16" x2="16" y2="16" />
    </symbol>
    <symbol id="i-calendar" viewBox="0 0 24 24">
      <rect x="3" y="4" width="18" height="18" rx="2" />
      <line x1="16" y1="2" x2="16" y2="6" />
      <line x1="8" y1="2" x2="8" y2="6" />
      <line x1="3" y1="10" x2="21" y2="10" />
    </symbol>
    <symbol id="i-cloud" viewBox="0 0 24 24">
      <polyline points="16 16 12 12 8 16" />
      <line x1="12" y1="12" x2="12" y2="21" />
      <path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3" />
    </symbol>
    <symbol id="i-lock" viewBox="0 0 24 24">
      <rect x="3" y="11" width="18" height="11" rx="2" />
      <path d="M7 11V7a5 5 0 0110 0v4" />
    </symbol>
    <symbol id="i-sun" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="5" />
      <line x1="12" y1="1" x2="12" y2="3" />
      <line x1="12" y1="21" x2="12" y2="23" />
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
      <line x1="1" y1="12" x2="3" y2="12" />
      <line x1="21" y1="12" x2="23" y2="12" />
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
    </symbol>
    <symbol id="i-moon" viewBox="0 0 24 24">
      <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
    </symbol>
    <symbol id="i-message" viewBox="0 0 24 24">
      <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
    </symbol>
    <symbol id="i-grid" viewBox="0 0 24 24">
      <rect x="3" y="3" width="7" height="7" />
      <rect x="14" y="3" width="7" height="7" />
      <rect x="14" y="14" width="7" height="7" />
      <rect x="3" y="14" width="7" height="7" />
    </symbol>
    <symbol id="i-users" viewBox="0 0 24 24">
      <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
      <circle cx="9" cy="7" r="4" />
      <path d="M23 21v-2a4 4 0 00-3-3.87" />
      <path d="M16 3.13a4 4 0 010 7.75" />
    </symbol>
  </svg>

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 h-16 flex items-center transition-all duration-400" id="nav">
    <div class="w-full max-w-[1100px] mx-auto px-5 md:px-10 flex items-center justify-between">
      <a href="#" class="flex items-center hover:opacity-70 transition-opacity">
        <img src="wamocon-logo.png" alt="WAMOCON" class="logo-img h-32 w-auto">
      </a>
      <!-- Desktop links -->
      <div class="hidden md:flex gap-8">
        <a href="#problem" class="magnetic-btn text-sm text-muted hover:text-text-main transition-colors">Problemstellung</a>
        <a href="#warum" class="magnetic-btn text-sm text-muted hover:text-text-main transition-colors">LFA</a>
        <a href="#funktionen" class="magnetic-btn text-sm text-muted hover:text-text-main transition-colors">Funktionen</a>
        <a href="#demo" class="magnetic-btn text-sm text-muted hover:text-text-main transition-colors">Demo</a>
        <a href="#faq" class="magnetic-btn text-sm text-muted hover:text-text-main transition-colors">FAQ</a>
      </div>
      <!-- Mobile hamburger -->
      <button class="nav-hamburger md:hidden" id="navHamburger" aria-label="Menü öffnen" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile fullscreen menu -->
  <div id="mobileMenu" aria-hidden="true" role="dialog" aria-label="Navigation">
    <a href="#problem" class="mm-link" onclick="closeMobileMenu()">Problemstellung</a>
    <div class="mm-divider"></div>
    <a href="#warum" class="mm-link" onclick="closeMobileMenu()">LFA</a>
    <div class="mm-divider"></div>
    <a href="#funktionen" class="mm-link" onclick="closeMobileMenu()">Funktionen</a>
    <div class="mm-divider"></div>
    <a href="#demo" class="mm-link" onclick="closeMobileMenu()">Demo</a>
    <div class="mm-divider"></div>
    <a href="#faq" class="mm-link" onclick="closeMobileMenu()">FAQ</a>
  </div>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden pb-[120px]" id="hero">
    <canvas id="heroParticles" class="absolute inset-0 z-[1]"></canvas>
    <div class="absolute inset-0 z-0"
      style="background:radial-gradient(ellipse 70% 55% at 50% 40%,rgba(255,26,26,.09)0%,transparent 65%),radial-gradient(ellipse 50% 60% at 20% 80%,rgba(255,26,26,.05)0%,transparent 50%),radial-gradient(ellipse 45% 50% at 80% 25%,rgba(140,0,0,.07)0%,transparent 50%)">
    </div>
    <div class="hero-grid absolute inset-0 z-0 opacity-100"
      style="background-image:linear-gradient(rgba(255,255,255,.018) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.018) 1px,transparent 1px);background-size:72px 72px;mask-image:radial-gradient(ellipse 60% 55% at 50% 50%,black 0%,transparent 70%)">
    </div>
    <div class="relative z-10 text-center max-w-[920px] px-5">
      <div
        class="reveal inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent-soft border border-border-accent text-xs font-medium tracking-widest uppercase text-accent mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-accent" style="animation:pulse 2s ease infinite"></span>Jetzt in der
        Pilotphase
      </div>
      <h1 class="reveal text-5xl md:text-7xl lg:text-8xl font-bold leading-[1.1] tracking-tight mb-6">Die Zukunft
        der<br><span class="gradient-text" id="heroTyping">FIAE Ausbildung.</span></h1>
      <p class="reveal text-lg md:text-xl text-muted max-w-[600px] mx-auto leading-relaxed">Die Plattform, auf der Ausbilder und Auszubildende direkt miteinander kommunizieren. Persönliches Feedback auf jede Aufgabe — verankert in IHK-Verordnungen und firmeneigenen Daten.</p>
      <p class="reveal text-xs text-faint mt-4 tracking-wide">Ein Produkt der WAMOCON GmbH</p>
    </div>
    <!-- Gradient fade into dark section -->
    <div class="absolute bottom-0 left-0 right-0 h-[120px] z-20" style="background:linear-gradient(to bottom, transparent, #0f0f11);"></div>
  </section>

  <!-- PROBLEM — Dark dramatic section for impact -->
  <section class="py-24 md:py-36 relative section-dark" id="problem" style="margin-top:-2px;">
    <div class="max-w-[1100px] mx-auto px-5 md:px-10">
      <span
        class="reveal inline-block text-xs font-semibold tracking-widest uppercase text-accent bg-accent-soft px-3 py-1 rounded mb-4">Problemstellung</span>
      <h2 class="reveal text-3xl md:text-5xl font-bold leading-[1.1] tracking-tight mb-5">Die FIAE-Ausbildung<br>steht vor dem Kollaps.</h2>
      <p class="reveal text-lg text-muted max-w-[620px] leading-relaxed">Während die Nachfrage nach IT-Spezialisten
        jährlich um 4,4 Prozent wächst, verbleibt die Ausbildungsinfrastruktur in fragmentierten Zuständen.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-14">
        <div class="reveal text-center p-8 rounded-2xl card-hover accent-hover" style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);"><span
            class="block text-4xl md:text-5xl font-bold gradient-text leading-none mb-3 tabular-nums"
            data-target="149000" data-separator=".">0</span><span class="block text-base font-medium mb-1">fehlende
            IT-Fachkräfte</span><span class="block text-sm text-faint">Quelle: Bitkom, Ende 2025</span></div>
        <div class="reveal text-center p-8 rounded-2xl card-hover accent-hover" style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);"><span
            class="block text-4xl md:text-5xl font-bold gradient-text leading-none mb-3 tabular-nums" data-target="76"
            data-suffix="%">0</span><span class="block text-base font-medium mb-1">überlastete Ausbilder</span><span
            class="block text-sm text-faint">Quelle: DGB Index Gute Arbeit</span></div>
        <div class="reveal text-center p-8 rounded-2xl card-hover accent-hover" style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);"><span
            class="block text-4xl md:text-5xl font-bold gradient-text leading-none mb-3 tabular-nums" data-target="30"
            data-suffix="%" data-prefix="bis ">0</span><span class="block text-base font-medium mb-1">Abbruchquote
            FIAE</span><span class="block text-sm text-faint">Quelle: BIBB Datenreport</span></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-10">
        <div class="reveal p-8 rounded-2xl card-hover" style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);">
          <span class="block text-xs font-medium tracking-widest uppercase text-faint mb-4">Verwaltungstools</span>
          <h3 class="text-xl font-semibold tracking-tight mb-3">Digitaler Papierkram</h3>
          <p class="text-sm text-muted leading-relaxed mb-5">Digitalisieren Formulare und Berichtshefte, ignorieren aber die fachliche Kompetenzentwicklung.</p>
          <span class="block text-sm font-semibold text-accent pt-4" style="border-top:1px solid rgba(255,255,255,.08);">Verwaltet das Dokument. Nicht den Skill.</span>
          <div class="mt-4 p-3 rounded-lg" style="background:rgba(255,26,26,.06);border:1px solid rgba(255,26,26,.1);">
            <span class="block text-xs font-semibold text-accent mb-1">LFA löst das:</span>
            <span class="block text-sm text-muted">Berichtshefte, Zeugnisse und Berichte automatisch generiert — Ausbilder konzentrieren sich auf echte Betreuung.</span>
          </div>
        </div>
        <div class="reveal p-8 rounded-2xl card-hover" style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);">
          <span class="block text-xs font-medium tracking-widest uppercase text-faint mb-4">E-Learning-Plattformen</span>
          <h3 class="text-xl font-semibold tracking-tight mb-3">Kontext-Blindheit</h3>
          <p class="text-sm text-muted leading-relaxed mb-5">Programmiersprachen werden abstrakt aus Lehrbüchern vermittelt — ohne Szenarien, Use Cases oder praxisnahe Quizze.</p>
          <span class="block text-sm font-semibold text-accent pt-4" style="border-top:1px solid rgba(255,255,255,.08);">Lehrt die Theorie. Nicht die Praxis.</span>
          <div class="mt-4 p-3 rounded-lg" style="background:rgba(255,26,26,.06);border:1px solid rgba(255,26,26,.1);">
            <span class="block text-xs font-semibold text-accent mb-1">LFA löst das:</span>
            <span class="block text-sm text-muted">Aus IHK-Büchern entstehen praxisnahe Szenarien, Use Cases und Quizze — Lernen wird greifbar statt abstrakt.</span>
          </div>
        </div>
        <div class="reveal p-8 rounded-2xl card-hover" style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);">
          <span class="block text-xs font-medium tracking-widest uppercase text-faint mb-4">Fehlende Struktur</span>
          <h3 class="text-xl font-semibold tracking-tight mb-3">Orientierungslos im Alltag</h3>
          <p class="text-sm text-muted leading-relaxed mb-5">Azubis starten ohne klare Struktur: Kein Überblick über Lernfortschritt, anstehende Prüfungen oder nächste Schritte.</p>
          <span class="block text-sm font-semibold text-accent pt-4" style="border-top:1px solid rgba(255,255,255,.08);">Improvisiert die Ausbildung. Statt sie zu führen.</span>
          <div class="mt-4 p-3 rounded-lg" style="background:rgba(255,26,26,.06);border:1px solid rgba(255,26,26,.1);">
            <span class="block text-xs font-semibold text-accent mb-1">LFA löst das:</span>
